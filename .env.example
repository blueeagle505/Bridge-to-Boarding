# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Works with any Postgres provider
# (Vercel Postgres, Supabase, Neon, Railway, RDS, local Postgres, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/bridge_to_boarding"

# ── Auth.js / NextAuth ─────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
# The canonical URL of your deployment (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Create a free API key at https://resend.com
# If left unset, the app will log emails to the console instead of sending
# them — useful for local development without a Resend account.
RESEND_API_KEY=""
EMAIL_FROM="Bridge to Boarding <onboarding@resend.dev>"
CONTACT_INBOX_EMAIL="hello@bridgetoboarding.org"

# ── First Administrator (one-time setup only) ───────────────────────────────
# Used ONLY by `npm run create-admin`, a one-time script you run after your
# first deploy. Do NOT commit real values. After the first admin exists,
# all future admins are created from the Admin Users page in the dashboard —
# these variables are not read anywhere else in the app.
FIRST_ADMIN_EMAIL="admin@example.com"
FIRST_ADMIN_PASSWORD="ChangeThisPassword123"
FIRST_ADMIN_FIRST_NAME="Founding"
FIRST_ADMIN_LAST_NAME="Admin"
